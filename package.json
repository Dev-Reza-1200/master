{
  "name": "ergonomic-report-app",
  "productName": "Ergonomic Evaluation Report",
  "description": "Desktop ergonomic evaluation report builder.",
  "author": "Ergonomic Works",
  "private": true,
  "version": "1.1.14",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently -k \"vite --host 127.0.0.1 --port 5173 --strictPort\" \"wait-on http://127.0.0.1:5173 && node scripts/launch-electron.cjs . --dev-server=http://127.0.0.1:5173\"",
    "dev:web": "vite --host 127.0.0.1 --port 5173 --strictPort",
    "start": "node scripts/launch-electron.cjs .",
    "build": "tsc && vite build",
    "test": "vitest",
    "test:layout": "node scripts/check-report-sequencing.cjs",
    "package:win": "npm run build && electron-builder --win portable nsis",
    "package:win:portable": "npm run build && electron-builder --win portable",
    "package:win:setup": "npm run build && electron-builder --win nsis",
    "preview": "vite preview --host 127.0.0.1 --port 4173 --strictPort"
  },
  "build": {
    "appId": "com.ergonomicworks.report",
    "productName": "Ergonomic Evaluation Report",
    "directories": {
      "output": "release"
    },
    "npmRebuild": true,
    "buildDependenciesFromSource": false,
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "asar": true,
    "asarUnpack": [
      "node_modules/better-sqlite3/**/*",
      "node_modules/pdfjs-dist/**/*"
    ],
    "win": {
      "icon": "public/assets/app-icon.ico",
      "signAndEditExecutable": false,
      "target": [
        "portable",
        "nsis"
      ]
    },
    "portable": {
      "artifactName": "Ergonomic-Evaluation-Report-Portable-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Ergonomic Evaluation Report",
      "artifactName": "Ergonomic-Evaluation-Report-Setup-${version}.${ext}"
    }
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^9.2.1",
    "electron": "^41.5.0",
    "electron-builder": "^26.8.1",
    "typescript": "~6.0.2",
    "vite": "^8.0.10",
    "wait-on": "^9.0.5"
    ,"vitest": "^1.3.0",
    "@testing-library/react": "^14.0.0",
    "@testing-library/jest-dom": "^6.0.1",
    "jsdom": "^22.1.0"
  },
  
  "dependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "adm-zip": "^0.5.17",
    "better-sqlite3": "^12.9.0",
    "lucide-react": "^1.14.0",
    "mammoth": "^1.8.0",
    "pdf-parse": "^1.1.1",
    "pdfjs-dist": "^3.11.174",
    "pdfkit": "^0.18.0",
    "pngjs": "^7.0.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "uuid": "^14.0.0",
    "xlsx": "^0.18.5"
  }
}
